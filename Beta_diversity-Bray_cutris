library(MatchIt)
library(cobalt)
##with aiming covariants matching and adjusments
meta <- read.csv("C:\\Users\\...\\meta_data.csv", row.names = 1)
otu <- read.csv("C:\\Users\\...\\OTU_table.csv",  row.names = 1, check.names = FALSE)
taxa <- read.csv("C:\\Users\\...\\taxa_table.csv", row.names =1, check.names = FALSE)

meta$Cancer <- factor(meta$Cancer, levels = c("NonGI", "GI"))
meta$age <- factor(meta$age)
meta$gender <- factor(meta$gender)
meta$Chemotherapy <- factor(meta$Chemotherapy)
meta$WHO <- factor(meta$WHO)

# Pairwise matching: each GI matched to one NonGI
m.out <- matchit(
  Cancer ~ age + BMI,
  data = meta,
  method = "nearest",
  distance = "mahalanobis",
  ratio = 1,
  exact = ~ gender + Chemotherapy + WHO
)

summary(m.out)
love.plot(m.out)

matched_meta <- match.data(m.out)

matched_meta[, c("Sample.ID", "Cancer.types", "age", "gender", "BMI",
                 "Chemotherapy", "WHO", "subclass")]
                 
matched_samples <- matched_meta$Sample

