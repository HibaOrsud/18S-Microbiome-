library(phyloseq)
library(ggplot2)

library(phyloseq)
library(vegan)
library(ggplot2)

bc <- phyloseq::distance(ps_matched, method = "bray")

pcoa <- cmdscale(bc, eig = TRUE, k = 2)

plot_df <- data.frame(
  PCoA1 = pcoa$points[,1],
  PCoA2 = pcoa$points[,2],
  Cancer = sample_data(ps_matched)$Cancer.types
)

ggplot(plot_df,
       aes(PCoA1, PCoA2, color = Cancer)) +
  geom_point(size = 4) +
  stat_ellipse(level = 0.95) +
  theme_bw(base_size = 14) +
  labs(
    title = "PCoA of Bray-Curtis Distances",
    subtitle = "PERMANOVA: R² = 0.20, p = 0.25"
  )
  
#colored  
plot_df <- data.frame(
  PCoA1 = pcoa$points[,1],
  PCoA2 = pcoa$points[,2],
  Sample.ID = rownames(pcoa$points)
)

plot_df <- merge(
  plot_df,
  matched_meta[, c("Sample.ID", "Cancer.types", "subclass")],
  by = "Sample.ID"
)

ggplot(plot_df,
       aes(PCoA1, PCoA2, color = Cancer.types)) +
  geom_point(size = 4) +
  stat_ellipse(aes(color = Cancer.types), level = 0.95) +
  theme_bw(base_size = 14) +
  labs(
    title = "PCoA of Bray-Curtis Distances",
    subtitle = "PERMANOVA: R² = 0.40, p = 0.705",
    color = "Cancer type"
  )  
  
#for match pairs  
library(ggrepel)

ggplot(plot_df,
       aes(PCoA1, PCoA2,
           color = Cancer.types,
           group = subclass)) +
  geom_line(alpha = 0.5) +
  geom_point(size = 4) +
  geom_text_repel(
    aes(label = Sample.ID),
    size = 4,
    max.overlaps = Inf
  ) +
  theme_bw(base_size = 14) +
  labs(
    title = "Bray-Curtis PCoA with Matched Pairs",
    subtitle = "PERMANOVA: R² = 0.20, p = 0.25",
    color = "Cancer type"
  )
