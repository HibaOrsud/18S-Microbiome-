## taxa prevalence
# Ensure your binary factor is included in the data frame

sample_data_df <- data.frame(sample_data(physeq))

physeq_df <- merge(physeq_df, sample_data_df, by.x = "Sample", by.y = "row.names")

# Order samples based on the binary factor for treatment type and cancer type (optional)

#physeq_df <- physeq_df %>%arrange(Treatment.type.x, Cancer.types.x, Event.status.x)

physeq_df <- physeq_df %>%

arrange(Cancer.types.x)

# Convert Sample to factor with the levels in the desired order

physeq_df$Sample <- factor(physeq_df$Sample, levels = unique(physeq_df$Sample))

physeq_df$Cancer.types.x <- as.numeric(as.character(physeq_df$Cancer.types.x))

#Save file to device:

write.csv(physeq_df, file = "physeq_df_its2-BF.csv", row.names
= TRUE)

# Print the plot

pg <- ggplot(physeq_df, aes(x = Sample, y = Abundance, fill = Phylum)) +

geom_bar(stat = "identity", position = "stack") +

theme_minimal() +

theme(legend.key.height = unit(0.15, "cm"),

axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1, size = 10),

axis.title.x = element_text(size = 12, face = "bold"),

axis.title.y = element_text(size = 12, face = "bold"))
+
scale_y_continuous(labels = scales::percent) +

labs(title = "Taxa Prevalence at Phylum Level-Cancer.types", x = "Samples", y = "Relative Abundance")

print(pg)
 
 
